{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "▶ Ejecutar en el Hub",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/pybricksdev.exe",
            "args": ["run", "ble", "${file}"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
